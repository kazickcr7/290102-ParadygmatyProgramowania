#include <iostream>
#include <string>

using namespace std;

class Osoba {
public:
    string imie, nazwisko, id;
    int wiek;
    int typ;

    Osoba(string i, string n, string _id, int w) {
        imie = i;
        nazwisko = n;
        id = _id;
        wiek = w;
        typ = 0;
    }
};

class Student : public Osoba {
public:
    string indeks;
    Student(string i, string n, string _id, int w, string ind) : Osoba(i, n, _id, w) {
        indeks = ind;
        typ = 1;
    }
};

class Stazysta : public Osoba {
public:
    string dzial;
    Stazysta(string i, string n, string _id, int w, string dz) : Osoba(i, n, _id, w) {
        dzial = dz;
        typ = 2;
    }
};

class ListaObecnosci {
public:
    Osoba **tabOsob;    
    bool *tabObecny;    
    int ilosc;
    int max;

    ListaObecnosci(int rozmiar = 10) {
        max = rozmiar;
        ilosc = 0;
        tabOsob = new Osoba*[max];
        tabObecny = new bool[max];
    }

    void dodaj(Osoba *os) {
        if (ilosc < max) {
            tabOsob[ilosc] = os;
            tabObecny[ilosc] = false;
            ilosc++;
        }
    }

    void wyswietlListe() {
        cout << "\nzawartosc listy" << endl;
        if (ilosc == 0) {
            cout << "lista jest pusta" << endl;
        }

        for (int i = 0; i < ilosc; i++) {
            cout << i << " ";
            
            if (tabOsob[i]->typ == 1) {
                Student *s = (Student*)tabOsob[i];
                cout << s->imie << " " << s->nazwisko << " [" << s->id << "] Indeks: " << s->indeks;
            } 
            else if (tabOsob[i]->typ == 2) {
                Stazysta *st = (Stazysta*)tabOsob[i];
                cout << st->imie << " " << st->nazwisko << " [" << st->id << "] Dzial: " << st->dzial;
            } 
            else {
                cout << tabOsob[i]->imie << " " << tabOsob[i]->nazwisko << " [" << tabOsob[i]->id << "]";
            }

            cout << " status ";
            if (tabObecny[i] == true) {
                cout << "potwierdzona obecnosc";
            } else {
                cout << "brak obecnosci";
            }
            cout << endl;
        }
        cout << endl;
    }

    void ustawObecnosc(string nazwisko, bool stan) {
        for (int i = 0; i < ilosc; i++) {
            if (tabOsob[i]->nazwisko == nazwisko) {
                tabObecny[i] = stan;
            }
        }
    }

    void usunZListy(string nazwisko) {
        for (int i = 0; i < ilosc; i++) {
            if (tabOsob[i]->nazwisko == nazwisko) {
                for (int j = i; j < ilosc - 1; j++) {
                    tabOsob[j] = tabOsob[j+1];
                    tabObecny[j] = tabObecny[j+1];
                }
                ilosc--;
                break;
            }
        }
    }
};

class InterfejsUzytkownika {
private:
    Osoba **tablicaOsob;
    int iloscOsob;
    ListaObecnosci **tablicaList;
    int iloscList;

public:
    InterfejsUzytkownika() {
        tablicaOsob = new Osoba*[100];
        iloscOsob = 0;
        tablicaList = new ListaObecnosci*[10];
        iloscList = 0;
    }

    void loop() {
        int wybor;
        string i_str, n, id_str, dodatek;
        int w;

        do {
            cout << "---------------------------" << endl;
            cout << "1 aby dodac osobe" << endl;
            cout << "8 aby dodac studenta" << endl;
            cout << "9 aby dodac stazyste" << endl;
            cout << "2 aby dodac liste" << endl;
            cout << "3 aby dodac osobe do listy" << endl;
            cout << "4 aby ustawic obecnosc" << endl;
            cout << "5 aby usunac osobe z listy" << endl;
            cout << "6 aby zmienic dane osoby" << endl;
            cout << "7 aby wyswietlic liste" << endl;
            cout << "0 wyjscie" << endl;
            cout << "wybor ";
            cin >> wybor;

            switch (wybor) {
                case 1:
                    cout << "podaj imie nazwisko id wiek ";
                    cin >> i_str >> n >> id_str >> w;
                    tablicaOsob[iloscOsob++] = new Osoba(i_str, n, id_str, w);
                    break;
                case 8:
                    cout << "podaj imie nazwisko id wiek indeks ";
                    cin >> i_str >> n >> id_str >> w >> dodatek;
                    tablicaOsob[iloscOsob++] = new Student(i_str, n, id_str, w, dodatek);
                    break;
                case 9:
                    cout << "podaj imie nazwisko id wiek dzial ";
                    cin >> i_str >> n >> id_str >> w >> dodatek;
                    tablicaOsob[iloscOsob++] = new Stazysta(i_str, n, id_str, w, dodatek);
                    break;
                case 2:
                    tablicaList[iloscList++] = new ListaObecnosci();
                    cout << "utworzono liste nr " << iloscList-1 << endl;
                    break;
                case 3: {
                    int nrListy;
                    cout << "nr listy i nazwisko "; cin >> nrListy >> n;
                    if(nrListy < iloscList) {
                        for(int i = 0; i < iloscOsob; i++) {
                            if(tablicaOsob[i]->nazwisko == n) {
                                tablicaList[nrListy]->dodaj(tablicaOsob[i]);
                            }
                        }
                    }
                    break;
                }
                case 4: {
                    int nrListy;
                    bool stan; cout << "nr listy nazwisko i stan 0 lub 1 "; cin >> nrListy >> n >> stan;
                    if(nrListy < iloscList) {
                        tablicaList[nrListy]->ustawObecnosc(n, stan);
                    }
                    break;
                }
                case 5: {
                    int nrListy;
                    cout << "nr listy i nazwisko "; cin >> nrListy >> n;
                    if(nrListy < iloscList) {
                        tablicaList[nrListy]->usunZListy(n);
                    }
                    break;
                }
                case 6:
                    cout << "nazwisko osoby do zmiany "; cin >> n;
                    for(int i = 0; i < iloscOsob; i++) {
                        if(tablicaOsob[i]->nazwisko == n) {
                            cout << "nowe imie "; cin >> tablicaOsob[i]->imie;
                        }
                    }
                    break;
                case 7: {
                    int nrListy;
                    cout << "ktora liste wyswietlic "; cin >> nrListy;
                    if(nrListy < iloscList) {
                        tablicaList[nrListy]->wyswietlListe();
                    }
                    break;
                }
            }
        } while (wybor != 0);
    }
};

int main() {
    InterfejsUzytkownika ui;
    ui.loop();
    return 0;
}
